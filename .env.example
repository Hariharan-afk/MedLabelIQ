POSTGRES_DB=medlabeliq
POSTGRES_USER=medlabeliq
POSTGRES_PASSWORD=medlabeliq
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# DailyMed ingestion
DAILYMED_BASE_URL=https://dailymed.nlm.nih.gov/dailymed/services/v2
HTTP_TIMEOUT_SECONDS=30
HTTP_USER_AGENT=MedLabelIQ/0.1 (research project)

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=medlabeliq_chunks

# Embeddings / retrieval
EMBEDDING_MODEL_NAME=<your-default-embedding-model-if-configurable>
EMBEDDING_BATCH_SIZE=32
RERANKER_CANDIDATE_POOL=30  

# Groq / LLM generation
LLM_API_KEY=YOUR_API_KEY
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=openai/gpt-oss-120b
LLM_TEMPERATURE=0
LLM_MAX_OUTPUT_TOKENS=1200
LLM_SEED=700

# Answer generation
ANSWER_TOP_K=5
ANSWER_CANDIDATE_POOL=15
EVIDENCE_MAX_PER_SECTION=1
ANSWER_VERIFIER_ENABLED=true

# Streamlit
MEDLABELIQ_API_BASE_URL=http://127.0.0.1:8011