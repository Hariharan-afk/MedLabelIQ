    {
      "section_uid": "58ac6ec5-66ab-4df7-ad73-bfee8ef2deac",
      "parent_section_uid": "08451794-56a6-496d-b526-4433bf3028d3",
      "order_index": 12,
      "depth": 1,
      "loinc_code": "34088-5",
      "code_display_name": "OVERDOSAGE SECTION",
      "raw_title": "Overdose warning",
      "normalized_title": "OVERDOSE WARNING",
      "canonical_section_name": "overdosage",
      "mapping_method": "loinc",
      "nearest_canonical_section_name": "overdosage",
      "nearest_canonical_source_section_uid": "58ac6ec5-66ab-4df7-ad73-bfee8ef2deac",
      "retrieval_family": "overdosage",
      "retrieval_family_source_section_uid": "58ac6ec5-66ab-4df7-ad73-bfee8ef2deac",
      "is_unclassified": false,
      "direct_text": "In case of overdose, get medical help or contact a Poison Control Center right away.(1-800-222-1222) Quick medical attention is critical for adults as well as for children even if you do not notice any signs or symptoms. This Unit Dose package is not child resistant and is Intended for Institutional Use Only.",
      "direct_text_sha256": "2499ebb2600830ffccaf6f16d3f4fab3d200cd92dfa2c98945278b7e3d145094",
      "direct_char_count": 310,
      "child_count": 0,
      "heading_path": [
        "WARNINGS SECTION",
        "Overdose warning"
      ]
    },
    {
      "section_uid": "46a2bea4-c58e-4114-9515-50809f429e88",
      "parent_section_uid": null,
      "order_index": 13,
      "depth": 0,
      "loinc_code": "34068-7",
      "code_display_name": "DOSAGE & ADMINISTRATION SECTION",
      "raw_title": "Directions",
      "normalized_title": "DIRECTIONS",
      "canonical_section_name": "dosage_and_administration",
      "mapping_method": "loinc",
      "nearest_canonical_section_name": "dosage_and_administration",
      "nearest_canonical_source_section_uid": "46a2bea4-c58e-4114-9515-50809f429e88",
      "retrieval_family": "dosage_and_administration",
      "retrieval_family_source_section_uid": "46a2bea4-c58e-4114-9515-50809f429e88",
      "is_unclassified": false,
      "direct_text": "\u2022 do not take more than directed (see overdose warning) \u2022 adults and children 12 years and over: \u2022 take 2 tablets every 4 to 6 hours while symptoms last \u2022 do not take more than 10 tablets in 24 hours, unless directed by a doctor \u2022 do not use for more than 10 days unless directed by a doctor \u2022 children 6 years to under 12 years o take 1 tablet every 4 to 6 hours while symptoms last \u2022 do not take more than 5 tablets in 24 hours \u2022 do not use for more than 5 days unless directed by a doctor \u2022 children under 6 years: ask a doctor",
      "direct_text_sha256": "3b8aeb722336978ff93d0729f5291308bb2e6e070df403bb0affdb82c27193d6",
      "direct_char_count": 530,
      "child_count": 0,
      "heading_path": [
        "Directions"
      ]
    },
