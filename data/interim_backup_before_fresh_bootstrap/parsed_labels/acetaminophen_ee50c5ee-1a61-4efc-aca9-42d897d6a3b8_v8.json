    {
      "section_uid": "bdb91ce4-12b7-43dc-ba72-5d8c923dbde2",
      "parent_section_uid": null,
      "order_index": 4,
      "depth": 0,
      "loinc_code": "34067-9",
      "code_display_name": "INDICATIONS & USAGE SECTION",
      "raw_title": "Uses",
      "normalized_title": "USES",
      "canonical_section_name": "indications_and_usage",
      "mapping_method": "loinc",
      "nearest_canonical_section_name": "indications_and_usage",
      "nearest_canonical_source_section_uid": "bdb91ce4-12b7-43dc-ba72-5d8c923dbde2",
      "retrieval_family": "indications_and_usage",
      "retrieval_family_source_section_uid": "bdb91ce4-12b7-43dc-ba72-5d8c923dbde2",
      "is_unclassified": false,
      "direct_text": "\u2022 temporarily relieves minor aches and pains due to: \u2022 headache \u2022 muscular aches \u2022 backache \u2022 minor pain of arthritis \u2022 the common cold \u2022 toothache \u2022 premenstrual and menstrual cramps \u2022 temporarily reduces fever",
      "direct_text_sha256": "8d489de85a4178d4e8d4937249a8fb3ea57091f6113d31eee72519a9c7cdbc74",
      "direct_char_count": 211,
      "child_count": 0,
      "heading_path": [
        "Uses"
      ]
    },
    {
      "section_uid": "08451794-56a6-496d-b526-4433bf3028d3",
      "parent_section_uid": null,
      "order_index": 5,
      "depth": 0,
      "loinc_code": "34071-1",
      "code_display_name": "WARNINGS SECTION",
      "raw_title": null,
      "normalized_title": null,
      "canonical_section_name": "warnings",
      "mapping_method": "loinc",
      "nearest_canonical_section_name": "warnings",
      "nearest_canonical_source_section_uid": "08451794-56a6-496d-b526-4433bf3028d3",
      "retrieval_family": "warnings",
      "retrieval_family_source_section_uid": "08451794-56a6-496d-b526-4433bf3028d3",
      "is_unclassified": false,
      "direct_text": "Liver warning: This product contains acetaminophen. The maximum daily dose of this product is 10 tablets (3,250 mg) in 24 hours for adults or 5 tablets (1,625 mg) in 24 hours for children. Severe liver damage may occur if \u2022 adult takes more than 4,000 mg of acetaminophen in 24 hours \u2022 child takes more than 5 doses in 24 hours, which is the maximum daily amount \u2022 taken with other drugs containing acetaminophen \u2022 adult has 3 or more alcoholic drinks every day while using this product Allergy alert: acetaminophen may cause severe skin reactions. Symptoms may include: \u2022 skin reddening \u2022 blisters \u2022 rash If a skin reaction occurs, stop use and seek medical help right away.",
      "direct_text_sha256": "960511710fad8bb5d4e062fc1c37d39bf14734cda095d58efa36649158e645ec",
      "direct_char_count": 675,
      "child_count": 7,
      "heading_path": [
        "WARNINGS SECTION"
      ]
    },
    {
      "section_uid": "9ecc22a5-33b4-41dd-bb96-19b1f2ebe91b",
      "parent_section_uid": "08451794-56a6-496d-b526-4433bf3028d3",
      "order_index": 6,
      "depth": 1,
      "loinc_code": "50570-1",
      "code_display_name": "OTC - DO NOT USE SECTION",
      "raw_title": "Do not use \uf03c",
      "normalized_title": "DO NOT USE",
      "canonical_section_name": "do_not_use",
      "mapping_method": "loinc",
      "nearest_canonical_section_name": "do_not_use",
      "nearest_canonical_source_section_uid": "9ecc22a5-33b4-41dd-bb96-19b1f2ebe91b",
      "retrieval_family": "do_not_use",
      "retrieval_family_source_section_uid": "9ecc22a5-33b4-41dd-bb96-19b1f2ebe91b",
      "is_unclassified": false,
      "direct_text": "\u2022 with any other drug containing acetaminophen (prescription or nonprescription). If you are not sure whether a drug contains acetaminophen, ask a doctor or pharmacist. \u2022 if you are allergic to acetaminophen or any of the inactive ingredients in this product",
      "direct_text_sha256": "b65e6ee6b036f80d01472e70928299748eb0c02832ce7d9520229c15d50a69a5",
      "direct_char_count": 258,
      "child_count": 0,
      "heading_path": [
        "WARNINGS SECTION",
        "Do not use \uf03c"
      ]
    },
    {
      "section_uid": "e0e1c993-32ec-46ff-9a53-402e54441ce9",
