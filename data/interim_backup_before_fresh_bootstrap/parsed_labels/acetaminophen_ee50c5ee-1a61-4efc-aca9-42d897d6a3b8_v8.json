      "retrieval_family": "ask_doctor_or_pharmacist_before_use",
      "retrieval_family_source_section_uid": "e6623c81-5bb8-47b2-bc0a-a34ec77c745c",
      "is_unclassified": false,
      "direct_text": "Ask a doctor or pharmacist before use if you are taking the blood thinning drug warfarin",
