    {
      "section_uid": "4f7e30f0-8d39-4ab4-8f5f-478fd96d071e",
      "parent_section_uid": "08451794-56a6-496d-b526-4433bf3028d3",
      "order_index": 9,
      "depth": 1,
      "loinc_code": "50566-9",
      "code_display_name": "OTC - STOP USE SECTION",
      "raw_title": null,
      "normalized_title": null,
      "canonical_section_name": "stop_use_and_ask_doctor",
      "mapping_method": "loinc",
      "nearest_canonical_section_name": "stop_use_and_ask_doctor",
      "nearest_canonical_source_section_uid": "4f7e30f0-8d39-4ab4-8f5f-478fd96d071e",
      "retrieval_family": "stop_use_and_ask_doctor",
      "retrieval_family_source_section_uid": "4f7e30f0-8d39-4ab4-8f5f-478fd96d071e",
      "is_unclassified": false,
      "direct_text": "Stop use and ask a doctor if \u2022 pain gets worse or lasts more than 10 days in adults \u2022 pain gets worse or lasts more than 5 days in children under 12 years \u2022 fever gets worse or lasts more than 3 days \u2022 new symptoms occur \u2022 redness or swelling is present These could be signs of a serious condition.",
      "direct_text_sha256": "ab77792ef238591eb3862c5e32bce3715668d9e138b4d4c4c79d94a372213923",
      "direct_char_count": 298,
      "child_count": 0,
      "heading_path": [
        "WARNINGS SECTION",
        "OTC - STOP USE SECTION"
      ]
    },
    {
